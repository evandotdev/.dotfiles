  "model": "opus",
  "availableModels": [
    "opus",
    "sonnet",
    "haiku",
    "opusplan"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/load-secrets.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input\" with title \"🔔 Claude Code\" subtitle \"'\"Tab $(($(echo $ITERM_SESSION_ID | sed 's/.*t\\([0-9]*\\).*/\\1/') + 1)).$(($(echo $ITERM_SESSION_ID | sed 's/.*p\\([0-9]*\\).*/\\1/') + 1)): $(basename $(pwd)) ($(git branch --show-current 2>/dev/null || echo 'no repo'))\"'\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"✅ Claude Code\" subtitle \"'\"Tab $(($(echo $ITERM_SESSION_ID | sed 's/.*t\\([0-9]*\\).*/\\1/') + 1)).$(($(echo $ITERM_SESSION_ID | sed 's/.*p\\([0-9]*\\).*/\\1/') + 1)): $(basename $(pwd)) ($(git branch --show-current 2>/dev/null || echo 'no repo'))\"'\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true
  },
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.42",
  "feedbackSurveyState": {
    "lastShownTime": 1753939765399
  }
}
