#!/usr/bin/env bash
source ./shared_vars
for loc in "${STOW_FOLDERS[@]}"; do
	stow -vD "$loc"
	if [[ "$loc" == "codex" ]]; then
		stow -v --adopt "$loc"
	else
		stow -v "$loc"
	fi
	echo
done

# register MCP servers for Claude Code (idempotent - overwrites if exists)
if command -v claude &>/dev/null; then
	claude mcp add --transport http exa "https://mcp.exa.ai/mcp"
	echo "Registered Exa MCP server for Claude Code"
fi
