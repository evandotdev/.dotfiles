#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    dirs=($(find ~/work ~/work/other-subnets ~/personal ~/git-worktrees ~/random-repos ~/saas-r-us -mindepth 1 -maxdepth 1 -type d 2>/dev/null))
    dirs+=("$HOME/.dotfiles")
    dirs+=("$HOME/pi-mono")
    selected=$(printf "%s\n" "${dirs[@]}" | fzf)
fi

[[ -z $selected ]] && exit 0

echo "$selected"
